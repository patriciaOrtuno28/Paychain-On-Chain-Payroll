{
  "name": "paychain-confidential-payroll",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "chain": "pnpm --filter @payroll/contracts run node",
    "deploy:local": "pnpm --filter @payroll/contracts run deploy:localhost",
    "contracts:export": "pnpm --filter @payroll/contracts run export:sdk:localhost",
    "deploy:sepolia": "pnpm --filter @payroll/contracts run deploy:sepolia",
    "contracts:export:sepolia": "pnpm --filter @payroll/contracts run export:sdk:sepolia",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint \"apps/**/*.{ts,tsx,js,jsx}\" \"packages/**/*.{ts,tsx,js,jsx}\" --max-warnings 0 --no-error-on-unmatched-pattern",
    "contracts:test": "pnpm --filter @payroll/contracts test",
    "web:build": "pnpm --filter @payroll/web build",
    "web": "pnpm --filter @payroll/web dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0",
    "typescript": "^5.5.4"
  }
}